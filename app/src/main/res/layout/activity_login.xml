<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تسجيل الدخول"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <!-- صورة شخصية (فقط في وضع التسجيل) -->
    <LinearLayout
        android:id="@+id/layoutProfilePicture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivProfilePicture"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/profile_circle"
            android:scaleType="centerCrop"
            android:contentDescription="صورة شخصية"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اضغط لإضافة صورة شخصية"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:gravity="center" />

    </LinearLayout>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="الاسم الكامل"
        android:textSize="18sp"
        android:textColorHint="#757575"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="right|center_vertical"
        android:inputType="textPersonName" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="البريد الإلكتروني"
        android:textSize="18sp"
        android:textColorHint="#757575"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="right|center_vertical"
        android:inputType="textEmailAddress" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="كلمة المرور"
        android:textSize="18sp"
        android:textColorHint="#757575"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:gravity="right|center_vertical"
        android:inputType="textPassword" />

    <LinearLayout
        android:id="@+id/layoutRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="دخول"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:layout_marginBottom="16dp"
        android:elevation="8dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSwitchMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ليس لديك حساب؟ سجل الآن"
        android:textSize="16sp"
        android:textColor="#2E7D32"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:gravity="center" />

</LinearLayout>

