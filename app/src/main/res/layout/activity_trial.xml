<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9"
    android:gravity="center"
    android:padding="24dp">

    <!-- العنوان -->
    <TextView
        android:id="@+id/tvTrialTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="جرب التطبيق مجاناً! 🎉"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- الوصف -->
    <TextView
        android:id="@+id/tvTrialDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="جرب تعلم حرف وكلمة قبل التسجيل"
        android:textSize="18sp"
        android:textColor="#4CAF50"
        android:layout_marginBottom="48dp"
        android:gravity="center" />

    <!-- محتوى التجربة -->
    <LinearLayout
        android:id="@+id/layoutTrialContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/trial_content_background"
        android:padding="24dp"
        android:layout_marginBottom="32dp">

        <!-- الحرف -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الحرف:"
            android:textSize="18sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvLetter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:layout_gravity="center" />

        <!-- الكلمة -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الكلمة:"
            android:textSize="18sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apple 🍎"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_gravity="center" />

    </LinearLayout>

    <!-- أزرار التجربة -->
    <Button
        android:id="@+id/btnTryLetter"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="🔊 استمع للحرف"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#FF6B6B"
        android:layout_marginBottom="16dp"
        android:elevation="4dp" />

    <Button
        android:id="@+id/btnTryWord"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="🔊 استمع للكلمة"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#4ECDC4"
        android:layout_marginBottom="32dp"
        android:elevation="4dp" />

    <!-- زر المتابعة -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="ابدأ التعلم الآن! 🚀"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:elevation="8dp" />

</LinearLayout>

